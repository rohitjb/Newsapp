Carthage/Build/

# fastlane
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/**/*.png
fastlane/test_output

# macOS
.DS_Store
DerivedData/

# Secrets — never commit
Secrets.xcconfig

# Visual companion
.superpowers/

